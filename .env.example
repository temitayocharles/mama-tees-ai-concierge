# Server
NODE_ENV=development
PORT=8080
CORS_ORIGIN=*
WEBHOOK_SECRET=replace-with-a-long-random-secret

# Logging destination: local_jsonl or google_sheets
LOG_DESTINATION=local_jsonl
LOCAL_LOG_PATH=storage/call-logs.jsonl

# Google Sheets. Required only when LOG_DESTINATION=google_sheets.
GOOGLE_SHEETS_SPREADSHEET_ID=1TYO9pj59qYfBeExiKLVYuvD9QB1jSFAhFb5rGBv4mB8
GOOGLE_SHEETS_TAB_NAME=Call Logs
GOOGLE_SERVICE_ACCOUNT_EMAIL=
# Put the private key on one line with escaped newlines, or use your host secret manager.
GOOGLE_PRIVATE_KEY=

# Business timezone
BUSINESS_TIMEZONE=Africa/Lagos
