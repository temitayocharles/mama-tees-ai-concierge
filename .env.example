# Server
NODE_ENV=development
PORT=8080
CORS_ORIGIN=*
WEBHOOK_SECRET=replace-with-a-long-random-secret

# Logging destination: local_jsonl or google_sheets
LOG_DESTINATION=local_jsonl
LOCAL_LOG_PATH=storage/call-logs.jsonl

# Google Sheets target. Required when LOG_DESTINATION=google_sheets.
GOOGLE_SHEETS_SPREADSHEET_ID=1TYO9pj59qYfBeExiKLVYuvD9QB1jSFAhFb5rGBv4mB8
GOOGLE_SHEETS_TAB_NAME=Call Logs

# Preferred production auth on Vercel: Workload Identity Federation through Vercel OIDC.
GCP_PROJECT_ID=
GCP_PROJECT_NUMBER=
GCP_SERVICE_ACCOUNT_EMAIL=
GCP_WORKLOAD_IDENTITY_POOL_ID=vercel
GCP_WORKLOAD_IDENTITY_POOL_PROVIDER_ID=vercel

# Legacy local/dev fallback only. Do not use JSON private keys for production if Vercel OIDC is available.
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY=

# Business timezone
BUSINESS_TIMEZONE=Africa/Lagos
