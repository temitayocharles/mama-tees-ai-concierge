        "language": "javaScript",
        "jsCode": "const first = $input.first();\nconst incoming = first?.json ?? {};\nconst body = incoming.body && typeof incoming.body === 'object' && !Array.isArray(incoming.body) ? incoming.body : incoming;\n\nconst payload = body && typeof body === 'object' && !Array.isArray(body) ? { ...body } : {};\n\nif (!payload.source) {\n  payload.source = 'n8n_fallback';\n}\n\nreturn [{ json: { payload } }];"
